{
  "name": "@clawlabz/clawnetwork-sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for ClawNetwork — AI agent blockchain",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^2.0.1",
    "borsh": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "clawnetwork",
    "blockchain",
    "ai-agent",
    "sdk",
    "ed25519"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ClawLabz/claw-network"
  }
}
